generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id String @id @default(uuid())
  name String
  email String @unique
  password String
  entries Entry[] 
}

model Entry {
  id String @id @default(uuid())
  title String
  artist String
  genres String[]
  rating Int
  note String
  userId String
  user User @relation(fields: [userId], references: [id])
  

  
}

